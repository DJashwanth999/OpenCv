   "source": [
    "# Program to display text on an image\n",
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "img=cv2.imread(\"puppy.jpg\")\n",
    "img=cv2.cvtColor(img,cv2.COLOR_BGR2RGB)\n",
    "cv2.putText(img,\"Simbha\",(20,50),\n",
    "cv2.FONT_HERSHEY_SIMPLEX,\n",
    "1,(255,0,0),2)\n",
    "plt.imshow(img)\n",
    "plt.show()"
   ]
