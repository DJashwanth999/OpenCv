   "source": [
    "# Program to draw a rectangle on an image\n",
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "img=cv2.imread(\"puppy.jpg\")\n",
    "img=cv2.cvtColor(img,cv2.COLOR_BGR2RGB)\n",
    "cv2.rectangle(img,(30,30),(180,150),(0,255,0),3)\n",
    "plt.imshow(img)\n",
    "plt.show()"
   ]
