   "source": [
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "img=cv2.imread(\"puppy.jpg\")\n",
    "img=cv2.cvtColor(img,cv2.COLOR_BGR2RGB)\n",
    "\n",
    "cv2.ellipse(img,(100,100),(80,40),0,0,360,(255,0,0),3)\n",
    "\n",
    "plt.imshow(img)\n",
    "plt.title(\"Ellipse\")\n",
    "plt.show()"
   ]
